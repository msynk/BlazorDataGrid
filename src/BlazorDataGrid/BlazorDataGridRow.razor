@typeparam TItem
@namespace BlazorDataGrid

<div class="@RowClass" role="row" style="@RowStyle" @onclick="OnRowClick"
     draggable="@(Grid.RowReorderable ? "true" : null)"
     @ondragstart="() => Grid.StartRowDrag(Item)"
     @ondragover:preventDefault="Grid.RowReorderable"
     @ondrop="() => Grid.DropRowAsync(Item)">

    @if (Grid.RowReorderable)
    {
        <div class="bdg-cell bdg-cell-reorder bdg-sticky" style="left:0;" role="gridcell" @onclick:stopPropagation="true">
            <span class="bdg-drag-handle" title="Drag to reorder">⠿</span>
        </div>
    }

    @if (Grid.HasDetailColumn)
    {
        <div class="bdg-cell bdg-cell-detail bdg-sticky" style="@Grid.DetailStickyStyle" role="gridcell" @onclick:stopPropagation="true">
            <button type="button" class="bdg-icon-btn" @onclick="() => Grid.ToggleDetail(Item)" aria-label="Toggle details">
                @(Grid.IsDetailExpanded(Item) ? "▾" : "▸")
            </button>
        </div>
    }

    @if (Grid.HasSelectColumn)
    {
        <div class="bdg-cell bdg-cell-select bdg-sticky" style="@Grid.SelectStickyStyle" role="gridcell" @onclick:stopPropagation="true">
            <input type="checkbox" checked="@Selected" disabled="@(!Grid.CanSelectRow(Item))"
                   @onchange="e => Grid.ToggleRowSelectionAsync(Item, (bool)e.Value!)" />
        </div>
    }

    @{
        var cols = Grid.VisibleColumns;
        var skip = 0;
    }
    @for (int ci = 0; ci < cols.Count; ci++)
    {
        if (skip > 0) { skip--; continue; }
        var column = cols[ci];
        var span = Grid.ResolveColSpan(column, Item);
        if (span > 1) skip = span - 1;
        var cellStyle = Grid.FrozenStyle(column) + (span > 1 ? $"grid-column:span {span};" : "");
        <div class="@CellClass(column)" role="gridcell" style="@cellStyle"
             @onclick="e => OnCellClick(column, e)"
             @ondblclick="e => Grid.HandleCellDoubleClickAsync(column, Item, e)"
             @oncontextmenu="e => Grid.HandleCellContextMenuAsync(column, Item, e)"
             @oncontextmenu:preventDefault="Grid.OnCellContextMenu.HasDelegate">
            @if (Editing && Grid.ColumnEditable(column))
            {
                @if (column.EditTemplate is not null)
                {
                    @column.EditTemplate(Item)
                }
                else
                {
                    <BlazorDataGridCellEditor TItem="TItem" Grid="Grid" Column="column" Item="Item" />
                }
            }
            else if (column.Template is not null)
            {
                @column.Template(Item)
            }
            else
            {
                @column.GetFormattedValue(Item)
            }
        </div>
    }

    @if (Grid.HasCommandColumn)
    {
        <div class="bdg-cell bdg-cell-command" role="gridcell" @onclick:stopPropagation="true">
            @if (Editing)
            {
                <button type="button" class="bdg-btn bdg-btn-primary" @onclick="Grid.CommitEditAsync">Save</button>
                <button type="button" class="bdg-btn" @onclick="Grid.CancelEditAsync">Cancel</button>
            }
            else
            {
                <button type="button" class="bdg-btn" @onclick="() => Grid.BeginEdit(Item)">Edit</button>
                <button type="button" class="bdg-btn bdg-btn-danger" @onclick="() => Grid.DeleteRowAsync(Item)">Delete</button>
            }
        </div>
    }
</div>

@if (Grid.HasDetailColumn && Grid.IsDetailExpanded(Item) && Grid.DetailTemplate is not null)
{
    <div class="bdg-detail-row" role="row">
        <div class="bdg-detail-content" role="gridcell">
            @Grid.DetailTemplate(Item)
        </div>
    </div>
}

@code {
    [Parameter, EditorRequired] public BlazorDataGrid<TItem> Grid { get; set; } = default!;
    [Parameter, EditorRequired] public TItem Item { get; set; } = default!;

    private bool Selected => Grid.IsRowSelected(Item);
    private bool Editing => Grid.IsEditing(Item);

    private string RowClass
    {
        get
        {
            var c = "bdg-row";
            if (Selected) c += " bdg-selected";
            if (Editing) c += " bdg-editing";
            return c;
        }
    }

    private string RowStyle =>
        $"grid-template-columns:var(--bdg-template);min-height:{Grid.ResolveRowHeight(Item).ToString(System.Globalization.CultureInfo.InvariantCulture)}px;";

    private string CellClass(BlazorDataGridColumn<TItem> column)
    {
        var c = "bdg-cell " + BlazorDataGrid<TItem>.AlignClass(column.Align);
        if (column.Frozen) c += " bdg-sticky";
        if (!string.IsNullOrEmpty(column.CellClass)) c += " " + column.CellClass;
        return c;
    }

    private Task OnRowClick() => Grid.HandleRowClickAsync(Item);

    private async Task OnCellClick(BlazorDataGridColumn<TItem> column, MouseEventArgs e)
        => await Grid.HandleCellClickAsync(column, Item, e);
}
