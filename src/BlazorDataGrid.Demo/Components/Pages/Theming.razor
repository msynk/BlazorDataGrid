@page "/theming"

<PageTitle>Theming &amp; RTL</PageTitle>

<h1>Theming &amp; RTL</h1>
<p class="lead">Restyle with CSS variables, toggle density, and switch to right-to-left layout.</p>

<p>
    The grid is themed entirely through CSS custom properties and the <code>light-dark()</code>
    function, so it follows the OS light/dark preference automatically. Override any
    <code>--bdg-*</code> token to create your own theme.
</p>

<div class="toolbar-row">
    <button class="btn @(_theme == "" ? "btn-accent" : "")" @onclick='() => _theme = ""'>Default</button>
    <button class="btn @(_theme == "theme-emerald" ? "btn-accent" : "")" @onclick='() => _theme = "theme-emerald"'>Emerald</button>
    <button class="btn @(_theme == "theme-grape" ? "btn-accent" : "")" @onclick='() => _theme = "theme-grape"'>Grape</button>
    <button class="btn" @onclick="() => _rtl = !_rtl">@(_rtl ? "LTR" : "RTL")</button>
    <button class="btn" @onclick="() => _bordered = !_bordered">Borders: @(_bordered ? "on" : "off")</button>
    <button class="btn" @onclick="() => _striped = !_striped">Striping: @(_striped ? "on" : "off")</button>
</div>

<div class="card">
    <DataGrid TItem="Product" Items="_products" Height="420px"
              Class="@_theme" Bordered="_bordered" Striped="_striped"
              Direction="@(_rtl ? GridDirection.Rtl : GridDirection.Ltr)"
              Sortable="true" Pageable="true" PageSize="8">
        <DataGridColumn TItem="Product" Field="Id" Title="ID" Width="70px" Align="ColumnAlign.Right" Frozen="true" />
        <DataGridColumn TItem="Product" Field="Name" Width="220px" />
        <DataGridColumn TItem="Product" Field="Category" />
        <DataGridColumn TItem="Product" Field="Price" Format="C2" Align="ColumnAlign.Right" />
        <DataGridColumn TItem="Product" Field="Stock" Align="ColumnAlign.Right" />
    </DataGrid>
</div>

<h2>Custom theme</h2>
<div class="card">
<pre><code>.theme-emerald {
    --bdg-accent: #0f9d58;
    --bdg-header-bg: light-dark(#e7f6ee, #10241a);
    --bdg-row-selected: light-dark(#c9efda, #14402a);
}</code></pre>
</div>

<style>
    .theme-emerald {
        --bdg-accent: #0f9d58;
        --bdg-header-bg: light-dark(#e7f6ee, #10241a);
        --bdg-row-selected: light-dark(#c9efda, #14402a);
    }
    .theme-grape {
        --bdg-accent: #8e44ad;
        --bdg-header-bg: light-dark(#f3e9f8, #241027);
        --bdg-row-selected: light-dark(#e7d2f0, #3a1a45);
    }
</style>

@code {
    private List<Product> _products = SampleData.Generate(60);
    private string _theme = "";
    private bool _rtl;
    private bool _bordered = true;
    private bool _striped = true;
}
