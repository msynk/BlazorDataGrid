@page "/cell-events"

<PageTitle>Cell Events &amp; Context Menu</PageTitle>

<h1>Cell events &amp; context menu</h1>
<p class="lead">React to cell clicks, double-clicks and right-clicks — build a custom context menu with no JS.</p>

<p>
    The grid raises <code>OnCellClick</code>, <code>OnCellDoubleClick</code> and
    <code>OnCellContextMenu</code> with the row, column and the underlying mouse event. Right-click a
    cell below to open a context menu positioned at the pointer (using the event's client
    coordinates).
</p>

<div class="card" @onclick="CloseMenu">
    <BlazorDataGrid TItem="Product" Items="_products" Height="420px"
                    OnCellClick="OnCellClick"
                    OnCellDoubleClick="OnCellDoubleClick"
                    OnCellContextMenu="OnCellContextMenu">
        <BlazorDataGridColumn TItem="Product" Field="Id" Title="ID" Width="70px" Align="BlazorDataGridColumnAlign.Right" />
        <BlazorDataGridColumn TItem="Product" Field="Name" Width="220px" />
        <BlazorDataGridColumn TItem="Product" Field="Category" />
        <BlazorDataGridColumn TItem="Product" Field="Price" Format="C2" Align="BlazorDataGridColumnAlign.Right" />
    </BlazorDataGrid>
</div>

<p class="hint">@_status</p>

@if (_menuVisible)
{
    <div class="ctx-menu" style="left:@(_menuX)px; top:@(_menuY)px;">
        <div class="ctx-title">@_menuTarget?.Name</div>
        <button class="ctx-item" @onclick='() => Act("View")'>View details</button>
        <button class="ctx-item" @onclick='() => Act("Duplicate")'>Duplicate</button>
        <button class="ctx-item ctx-danger" @onclick='() => Act("Delete")'>Delete</button>
    </div>
}

<style>
    .ctx-menu {
        position: fixed;
        z-index: 9999;
        min-width: 160px;
        background: var(--panel-bg);
        border: 1px solid var(--border);
        border-radius: 8px;
        box-shadow: 0 8px 24px rgba(0,0,0,.18);
        padding: 4px;
    }
    .ctx-title { padding: 6px 10px; font-weight: 600; color: var(--muted); font-size: 12px; }
    .ctx-item {
        display: block; width: 100%; text-align: left;
        padding: 7px 10px; border: none; background: none; color: var(--text);
        cursor: pointer; border-radius: 6px; font: inherit;
    }
    .ctx-item:hover { background: var(--accent); color: #fff; }
    .ctx-danger { color: light-dark(#cf222e, #ff7b72); }
    .ctx-danger:hover { background: #cf222e; color: #fff; }
</style>

@code {
    private List<Product> _products = SampleData.Generate(40);
    private string _status = "Click, double-click or right-click any cell.";

    private bool _menuVisible;
    private double _menuX, _menuY;
    private Product? _menuTarget;

    private void OnCellClick(BlazorDataGridCellEventArgs<Product> e)
    {
        _status = $"Clicked {e.ColumnTitle} = \"{e.Value}\" on {e.Item.Name}";
        CloseMenu();
    }

    private void OnCellDoubleClick(BlazorDataGridCellEventArgs<Product> e)
    {
        _status = $"Double-clicked {e.ColumnTitle} on {e.Item.Name}";
    }

    private void OnCellContextMenu(BlazorDataGridCellEventArgs<Product> e)
    {
        _menuTarget = e.Item;
        _menuX = e.Mouse.ClientX;
        _menuY = e.Mouse.ClientY;
        _menuVisible = true;
    }

    private void Act(string action)
    {
        _status = $"{action} → {_menuTarget?.Name}";
        CloseMenu();
    }

    private void CloseMenu() => _menuVisible = false;
}
