@page "/filtering"

<PageTitle>Filtering &amp; Paging</PageTitle>

<h1>Filtering &amp; paging</h1>
<p class="lead">A quick-filter row sits under the header; the pager controls page size and navigation.</p>

<p>
    Type in any filter box to narrow results (case-insensitive contains). Combine filters across
    columns. Paging recalculates automatically and resets to the first page when filters change.
</p>

<div class="card">
    <DataGrid TItem="Product" Items="_products" Height="430px"
              Filterable="true" Pageable="true" PageSize="10"
              PagerPosition="PagerPosition.Bottom"
              ShowToolbar="true" ShowCsvExport="true">
        <DataGridColumn TItem="Product" Field="Id" Title="ID" Width="70px" Align="ColumnAlign.Right" Filterable="false" />
        <DataGridColumn TItem="Product" Field="Name" Width="220px" />
        <DataGridColumn TItem="Product" Field="Category" />
        <DataGridColumn TItem="Product" Field="Supplier" />
        <DataGridColumn TItem="Product" Field="Price" Format="C2" Align="ColumnAlign.Right" />
        <DataGridColumn TItem="Product" Field="Stock" Align="ColumnAlign.Right" />
    </DataGrid>
</div>

<p class="hint">Tip: set <code>PageSizeOptions</code> to customize the page-size dropdown.</p>

@code {
    private List<Product> _products = SampleData.Generate(200);
}
