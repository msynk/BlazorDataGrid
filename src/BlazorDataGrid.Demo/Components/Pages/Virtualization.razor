@page "/virtualization"

<PageTitle>Virtualization</PageTitle>

<h1>Virtualization</h1>
<p class="lead">Render very large datasets smoothly — only visible rows hit the DOM.</p>

<p>
    This grid binds <strong>@_products.Count.ToString("N0")</strong> rows. Virtualization is powered by
    Blazor's built-in <code>Virtualize</code> component, so scrolling stays responsive without any
    custom JavaScript. A fixed <code>Height</code> and <code>RowHeight</code> are required.
</p>

<div class="toolbar-row">
    <button class="btn" @onclick="() => Resize(1_000)">1k rows</button>
    <button class="btn" @onclick="() => Resize(10_000)">10k rows</button>
    <button class="btn" @onclick="() => Resize(100_000)">100k rows</button>
</div>

<div class="card">
    <BlazorDataGrid TItem="Product" Items="_products" Height="520px"
              Virtualize="true" RowHeight="36" Sortable="true" Filterable="true">
        <BlazorDataGridColumn TItem="Product" Field="Id" Title="ID" Width="90px" Align="BlazorDataGridColumnAlign.Right" Filterable="false" />
        <BlazorDataGridColumn TItem="Product" Field="Name" Width="240px" />
        <BlazorDataGridColumn TItem="Product" Field="Category" />
        <BlazorDataGridColumn TItem="Product" Field="Supplier" />
        <BlazorDataGridColumn TItem="Product" Field="Price" Format="C2" Align="BlazorDataGridColumnAlign.Right" />
        <BlazorDataGridColumn TItem="Product" Field="Stock" Align="BlazorDataGridColumnAlign.Right" />
        <BlazorDataGridColumn TItem="Product" Field="Rating" Format="N1" Align="BlazorDataGridColumnAlign.Right" />
    </BlazorDataGrid>
</div>

<h2>Markup</h2>
<div class="card">
<pre><code>&lt;BlazorDataGrid TItem="Product" Items="products" Height="520px"
                Virtualize="true" RowHeight="36" Sortable="true" Filterable="true"&gt;
    &lt;BlazorDataGridColumn TItem="Product" Field="Id" Title="ID" Filterable="false" /&gt;
    &lt;BlazorDataGridColumn TItem="Product" Field="Name" /&gt;
    &lt;BlazorDataGridColumn TItem="Product" Field="Price" Format="C2" /&gt;
&lt;/BlazorDataGrid&gt;</code></pre>
</div>

@code {
    private List<Product> _products = SampleData.Generate(10_000);

    private void Resize(int count) => _products = SampleData.Generate(count);
}
