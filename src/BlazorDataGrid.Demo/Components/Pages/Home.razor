@page "/"

<PageTitle>BlazorDataGrid · Overview</PageTitle>

<h1>BlazorDataGrid</h1>
<p class="lead">A feature-rich, native Blazor data grid for .NET 10 — built with minimal JavaScript.</p>

<p>
    This component library implements the capabilities you expect from a top-tier data grid
    (inspired by react-data-grid, MUI X, AG Grid and Syncfusion), using idiomatic Blazor:
    CSS Grid layout, the built-in <code>Virtualize</code> component, CSS <code>position: sticky</code>
    for frozen columns/headers, and native HTML drag-and-drop. Column resizing uses a pure-Blazor
    pointer overlay — no custom JS at all.
</p>

<div class="feature-grid">
    <div class="feature"><h3>Sorting</h3><p>Single &amp; multi-column (Ctrl/?+click) with priority badges.</p></div>
    <div class="feature"><h3>Filtering</h3><p>Per-column quick filters plus a rich operator API.</p></div>
    <div class="feature"><h3>Paging</h3><p>Configurable page sizes, top/bottom pager.</p></div>
    <div class="feature"><h3>Virtualization</h3><p>Render 100k+ rows smoothly via <code>Virtualize</code>.</p></div>
    <div class="feature"><h3>Selection</h3><p>Single / multiple with select-all checkbox.</p></div>
    <div class="feature"><h3>Inline editing</h3><p>Typed editors, add / save / cancel / delete.</p></div>
    <div class="feature"><h3>Grouping</h3><p>Collapsible groups with per-group aggregates.</p></div>
    <div class="feature"><h3>Aggregates</h3><p>Sum, Avg, Count, Min, Max footer rows.</p></div>
    <div class="feature"><h3>Resize</h3><p>Drag column edges — zero JavaScript.</p></div>
    <div class="feature"><h3>Reorder</h3><p>Native drag-and-drop column ordering.</p></div>
    <div class="feature"><h3>Frozen columns</h3><p>Pin columns &amp; headers while scrolling.</p></div>
    <div class="feature"><h3>Templates</h3><p>Cell, header, editor, footer &amp; detail templates.</p></div>
    <div class="feature"><h3>Server-side</h3><p><code>OnRead</code> hook for DB-backed paging/sorting.</p></div>
    <div class="feature"><h3>Theming</h3><p>CSS variables, light/dark &amp; RTL support.</p></div>
    <div class="feature"><h3>CSV export</h3><p>One-click export of the current view.</p></div>
    <div class="feature"><h3>Accessible</h3><p>ARIA grid roles &amp; keyboard-friendly controls.</p></div>
</div>

<h2>Kitchen-sink example</h2>
<p class="lead">Most features enabled at once. Try sorting, filtering, paging, selecting and exporting.</p>

<div class="card">
    <BlazorDataGrid TItem="Product" Items="_products" Height="460px"
              Pageable="true" PageSize="8"
              Filterable="true" Sortable="true" MultiSort="true"
              SelectionMode="BlazorDataGridSelectionMode.Multiple"
              ShowFooter="true" ShowToolbar="true" ShowColumnChooser="true" ShowCsvExport="true"
              Resizable="true" Reorderable="true"
              @bind-SelectedItems="_selected">
        <BlazorDataGridColumn TItem="Product" Field="Id" Title="ID" Width="70px" Align="BlazorDataGridColumnAlign.Right" Frozen="true" />
        <BlazorDataGridColumn TItem="Product" Field="Name" Width="200px" />
        <BlazorDataGridColumn TItem="Product" Field="Category" />
        <BlazorDataGridColumn TItem="Product" Field="Supplier" />
        <BlazorDataGridColumn TItem="Product" Field="Price" Format="C2" Align="BlazorDataGridColumnAlign.Right" Aggregate="BlazorDataGridAggregateType.Average" />
        <BlazorDataGridColumn TItem="Product" Field="Stock" Align="BlazorDataGridColumnAlign.Right" Aggregate="BlazorDataGridAggregateType.Sum" />
        <BlazorDataGridColumn TItem="Product" Field="Rating" Format="N1" Align="BlazorDataGridColumnAlign.Right" />
        <BlazorDataGridColumn TItem="Product" Field="ReleaseDate" Title="Released" Format="yyyy-MM-dd" />
        <BlazorDataGridColumn TItem="Product" Field="Discontinued" Title="Active">
            <Template Context="p">
                <span class="badge @(p.Discontinued ? "badge-off" : "badge-on")">
                    @(p.Discontinued ? "No" : "Yes")
                </span>
            </Template>
        </BlazorDataGridColumn>
    </BlazorDataGrid>
</div>
<p class="hint">Selected: @_selected.Count item(s).</p>

@code {
    private List<Product> _products = SampleData.Generate(120);
    private IReadOnlyList<Product> _selected = new List<Product>();
}
