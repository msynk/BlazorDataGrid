@page "/cell-navigation"

<PageTitle>Cell Navigation</PageTitle>

<h1>Keyboard cell navigation</h1>
<p class="lead">Move a focus ring around the grid with the keyboard — no mouse required.</p>

<p>
    Set <code>CellNavigation="true"</code> and the grid follows the ARIA grid pattern: a single
    roving tab stop lets you <kbd>Tab</kbd> into the grid, then move with the keyboard. Focus is
    driven entirely by Blazor's built-in <code>FocusAsync</code> — there is no JavaScript.
</p>

<ul class="keys">
    <li><kbd>↑</kbd> <kbd>↓</kbd> <kbd>←</kbd> <kbd>→</kbd> — move one cell</li>
    <li><kbd>Home</kbd> / <kbd>End</kbd> — first / last cell in the row</li>
    <li><kbd>Ctrl</kbd>+<kbd>Home</kbd> / <kbd>Ctrl</kbd>+<kbd>End</kbd> — first / last cell in the grid</li>
    <li><kbd>PageUp</kbd> / <kbd>PageDown</kbd> — jump 10 rows</li>
    <li><kbd>Enter</kbd> or <kbd>F2</kbd> — edit the focused cell, <kbd>Esc</kbd> — cancel</li>
</ul>

<div class="card">
    <BlazorDataGrid TItem="Product" Items="_products" Height="460px"
                    CellNavigation="true" Sortable="true" Editable="true"
                    OnRowSave="_ => {}">
        <BlazorDataGridColumn TItem="Product" Field="Id" Title="ID" Width="70px"
                              Align="BlazorDataGridColumnAlign.Right" Editable="false" />
        <BlazorDataGridColumn TItem="Product" Field="Name" Width="220px" />
        <BlazorDataGridColumn TItem="Product" Field="Category" />
        <BlazorDataGridColumn TItem="Product" Field="Price" Format="C2" Align="BlazorDataGridColumnAlign.Right" />
        <BlazorDataGridColumn TItem="Product" Field="Stock" Align="BlazorDataGridColumnAlign.Right" />
        <BlazorDataGridColumn TItem="Product" Field="Rating" Format="N1" Align="BlazorDataGridColumnAlign.Right" />
    </BlazorDataGrid>
</div>

<p class="hint">Click any cell or press <kbd>Tab</kbd> to enter the grid, then use the arrow keys.</p>

@code {
    private List<Product> _products = SampleData.Generate(40);
}
