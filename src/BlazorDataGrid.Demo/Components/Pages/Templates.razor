@page "/templates"

<PageTitle>Templates &amp; Details</PageTitle>

<h1>Templates &amp; detail rows</h1>
<p class="lead">Customize any cell, header or footer, and expand rows to reveal detail content.</p>

<div class="card">
    <BlazorDataGrid TItem="Product" Items="_products" Height="470px" Sortable="true" ShowFooter="true">
        <DetailTemplate Context="p">
            <div style="display:flex; gap:32px; flex-wrap:wrap;">
                <div><strong>Supplier</strong><br />@p.Supplier</div>
                <div><strong>Released</strong><br />@p.ReleaseDate.ToString("D")</div>
                <div><strong>Inventory value</strong><br />@((p.Price * p.Stock).ToString("C2"))</div>
                <div><strong>Status</strong><br />@(p.Discontinued ? "Discontinued" : "Active")</div>
            </div>
        </DetailTemplate>

        <ChildContent>
            <BlazorDataGridColumn TItem="Product" Field="Name" Width="220px">
                <HeaderTemplate>📦 Product</HeaderTemplate>
            </BlazorDataGridColumn>
            <BlazorDataGridColumn TItem="Product" Field="Category" />
            <BlazorDataGridColumn TItem="Product" Field="Rating" Title="Rating" Align="BlazorDataGridColumnAlign.Left">
                <Template Context="p">
                    <span title="@p.Rating">
                        @for (var i = 0; i < 5; i++)
                        {
                            <span style="color:@(i < Math.Round(p.Rating) ? "#f5a623" : "#ccc")">★</span>
                        }
                    </span>
                </Template>
            </BlazorDataGridColumn>
            <BlazorDataGridColumn TItem="Product" Field="Price" Format="C2" Align="BlazorDataGridColumnAlign.Right"
                            Aggregate="BlazorDataGridAggregateType.Sum">
                <FooterTemplate Context="agg">
                    <span>Total: @agg.FormattedValue</span>
                </FooterTemplate>
            </BlazorDataGridColumn>
            <BlazorDataGridColumn TItem="Product" Field="Stock" Align="BlazorDataGridColumnAlign.Right">
                <Template Context="p">
                    <span class="badge @(p.Stock == 0 ? "badge-off" : "badge-on")">
                        @(p.Stock == 0 ? "Out of stock" : $"{p.Stock} in stock")
                    </span>
                </Template>
            </BlazorDataGridColumn>
        </ChildContent>
    </BlazorDataGrid>
</div>

<p class="hint">Click the ▸ toggle on the left of a row to expand its detail panel.</p>

<h2>Markup</h2>
<div class="card">
<pre><code>&lt;BlazorDataGrid TItem="Product" Items="products" Sortable="true" ShowFooter="true"&gt;
    &lt;DetailTemplate Context="p"&gt;
        &lt;div&gt;Supplier: @@p.Supplier&lt;/div&gt;
    &lt;/DetailTemplate&gt;
    &lt;ChildContent&gt;
        &lt;BlazorDataGridColumn TItem="Product" Field="Name"&gt;
            &lt;HeaderTemplate&gt;📦 Product&lt;/HeaderTemplate&gt;
        &lt;/BlazorDataGridColumn&gt;
        &lt;BlazorDataGridColumn TItem="Product" Field="Stock"&gt;
            &lt;Template Context="p"&gt;@@p.Stock in stock&lt;/Template&gt;
        &lt;/BlazorDataGridColumn&gt;
        &lt;BlazorDataGridColumn TItem="Product" Field="Price" Format="C2"
                              Aggregate="BlazorDataGridAggregateType.Sum"&gt;
            &lt;FooterTemplate Context="agg"&gt;Total: @@agg.FormattedValue&lt;/FooterTemplate&gt;
        &lt;/BlazorDataGridColumn&gt;
    &lt;/ChildContent&gt;
&lt;/BlazorDataGrid&gt;</code></pre>
</div>

@code {
    private List<Product> _products = SampleData.Generate(30);
}
