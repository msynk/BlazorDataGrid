@page "/basic"

<PageTitle>Basic &amp; Sorting</PageTitle>

<h1>Basic usage &amp; sorting</h1>
<p class="lead">Bind a collection, declare columns, and you get sorting out of the box.</p>

<p>
    Click a header to sort ascending → descending → unsorted. Hold <kbd>Ctrl</kbd>
    (or <kbd>⌘</kbd>) and click additional headers for multi-column sorting; the small
    badge shows the sort priority.
</p>

<div class="card">
    <BlazorDataGrid TItem="Product" Items="_products" Height="430px" MultiSort="true">
        <BlazorDataGridColumn TItem="Product" Field="Id" Title="ID" Width="70px" Align="BlazorDataGridColumnAlign.Right" />
        <BlazorDataGridColumn TItem="Product" Field="Name" Width="220px" />
        <BlazorDataGridColumn TItem="Product" Field="Category" />
        <BlazorDataGridColumn TItem="Product" Field="Price" Format="C2" Align="BlazorDataGridColumnAlign.Right" />
        <BlazorDataGridColumn TItem="Product" Field="Stock" Align="BlazorDataGridColumnAlign.Right" />
        <BlazorDataGridColumn TItem="Product" Field="Rating" Format="N1" Align="BlazorDataGridColumnAlign.Right" />
    </BlazorDataGrid>
</div>

<h2>Markup</h2>
<div class="card">
<pre><code>&lt;BlazorDataGrid TItem="Product" Items="products" MultiSort="true"&gt;
    &lt;BlazorDataGridColumn TItem="Product" Field="Id" Title="ID" Align="BlazorDataGridColumnAlign.Right" /&gt;
    &lt;BlazorDataGridColumn TItem="Product" Field="Name" /&gt;
    &lt;BlazorDataGridColumn TItem="Product" Field="Price" Format="C2" /&gt;
&lt;/BlazorDataGrid&gt;</code></pre>
</div>

@code {
    private List<Product> _products = SampleData.Generate(50);
}
